{
  "name": "beaver-cli",
  "version": "0.2.0",
  "description": "Analyze coding agent sessions, detect friction, suggest improvements that compound over time.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "beaver": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
