    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "agent",
    "analysis",
    "friction",
    "developer-tools"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
